# Docker Compose PostgreSQL
POSTGRES_USER=lsm
POSTGRES_PASSWORD=lsm_dev_password
POSTGRES_DB=lsm_dev
POSTGRES_PORT=5434

# Backend (copy also to backend/.env — see backend/.env.example)
DATABASE_URL=postgresql://lsm:lsm_dev_password@localhost:5434/lsm_dev?schema=public
PORT=3000
APP_ENV=development
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
LOG_LEVEL=info
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
BODY_LIMIT=1mb
TRUST_PROXY=false
