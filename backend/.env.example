# Application
PORT=3000
APP_ENV=development
NODE_ENV=development

# Database (must match docker-compose credentials)
DATABASE_URL=postgresql://lsm:lsm_dev_password@localhost:5434/lsm_dev?schema=public

# HTTP / security
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
BODY_LIMIT=1mb
TRUST_PROXY=false
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=info

# Identity / JWT (use long random secrets in real environments)
JWT_ACCESS_SECRET=dev_access_secret_change_me_32chars_min
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_32chars_min
JWT_REFRESH_TTL=7d
