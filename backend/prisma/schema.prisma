// Prisma schema — Phase 1 Identity + Phase 2 Provider/Customer Profiles.
// Listings, categories, bookings, and other marketplace domains arrive later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMINISTRATOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ProfileStatus {
  ACTIVE
  DEACTIVATED
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  displayName     String?
  role            UserRole         @default(CUSTOMER)
  status          UserStatus       @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  refreshTokens   RefreshToken[]
  providerProfile ProviderProfile?
  customerProfile CustomerProfile?

  @@index([status])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Marketplace business identity for a service provider. Not a service listing.
model ProviderProfile {
  id               String            @id @default(cuid())
  userId           String            @unique
  displayName      String
  businessName     String?
  description      String?
  contactEmail     String?
  contactPhone     String?
  websiteUrl       String?
  logoUrl          String?
  coverImageUrl    String?
  languages        String[]          @default([])
  businessSettings Json              @default("{}")
  visibility       ProfileVisibility @default(PRIVATE)
  status           ProfileStatus     @default(ACTIVE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, visibility])
}

/// Marketplace customer identity. Separate from User auth and ProviderProfile.
model CustomerProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  displayName   String
  avatarUrl     String?
  contactEmail  String?
  contactPhone  String?
  preferences   Json          @default("{}")
  savedSettings Json          @default("{}")
  status        ProfileStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}
