// Prisma schema — Phase 1–3: Identity, Profiles, Categories, Maldives Geography, Coverage.
// Listings, bookings, and other marketplace domains arrive later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMINISTRATOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ProfileStatus {
  ACTIVE
  DEACTIVATED
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
}

enum IslandType {
  CAPITAL
  CITY
  INHABITED
  RESORT
  AIRPORT
  INDUSTRIAL
  OTHER
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  displayName     String?
  role            UserRole         @default(CUSTOMER)
  status          UserStatus       @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  refreshTokens   RefreshToken[]
  providerProfile ProviderProfile?
  customerProfile CustomerProfile?

  @@index([status])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Marketplace business identity for a service provider. Not a service listing.
model ProviderProfile {
  id               String                   @id @default(cuid())
  userId           String                   @unique
  displayName      String
  businessName     String?
  description      String?
  contactEmail     String?
  contactPhone     String?
  websiteUrl       String?
  logoUrl          String?
  coverImageUrl    String?
  languages        String[]                 @default([])
  businessSettings Json                     @default("{}")
  visibility       ProfileVisibility        @default(PRIVATE)
  status           ProfileStatus            @default(ACTIVE)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceCoverages ProviderIslandCoverage[]

  @@index([status, visibility])
}

/// Marketplace customer identity. Separate from User auth and ProviderProfile.
model CustomerProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  displayName   String
  avatarUrl     String?
  contactEmail  String?
  contactPhone  String?
  preferences   Json          @default("{}")
  savedSettings Json          @default("{}")
  status        ProfileStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

/// Service taxonomy. Parent-child hierarchy; unlimited depth.
model Category {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String?
  icon         String?
  parentId     String?
  displayOrder Int           @default(0)
  status       CatalogStatus @default(ACTIVE)
  metadata     Json          @default("{}")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  parent       Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children     Category[]    @relation("CategoryHierarchy")

  @@index([parentId])
  @@index([status, displayOrder])
}

/// Maldives administrative atoll (or city-atoll equivalent). Country is fixed as Maldives.
model Atoll {
  id           String        @id @default(cuid())
  name         String
  code         String        @unique
  description  String?
  displayOrder Int           @default(0)
  status       CatalogStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  islands      Island[]

  @@index([status, displayOrder])
}

/// Island within a Maldives atoll.
model Island {
  id           String                   @id @default(cuid())
  atollId      String
  name         String
  slug         String                   @unique
  type         IslandType               @default(INHABITED)
  displayOrder Int                      @default(0)
  status       CatalogStatus            @default(ACTIVE)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  atoll        Atoll                    @relation(fields: [atollId], references: [id], onDelete: Restrict)
  coverages    ProviderIslandCoverage[]

  @@unique([atollId, name])
  @@index([atollId])
  @@index([status, displayOrder])
}

/// Provider service coverage normalized to individual islands.
model ProviderIslandCoverage {
  id                String          @id @default(cuid())
  providerProfileId String
  islandId          String
  createdAt         DateTime        @default(now())
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  island            Island          @relation(fields: [islandId], references: [id], onDelete: Restrict)

  @@unique([providerProfileId, islandId])
  @@index([providerProfileId])
  @@index([islandId])
}
